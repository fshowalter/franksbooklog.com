---
import type { CollectionEntry } from "astro:content";

import { getCollection } from "astro:content";

import ReviewPage from "~/features/review/ReviewPage.astro";

type Props = {
  reviewedWork: CollectionEntry<"reviewedWorks">["data"];
};

export async function getStaticPaths() {
  const reviewedWorks = await getCollection("reviewedWorks");

  return reviewedWorks.map((reviewedWork) => {
    return {
      params: {
        slug: reviewedWork.data.review.id,
      },
      props: {
        reviewedWork: reviewedWork.data,
      },
    };
  });
}

const { reviewedWork } = Astro.props;
---

<ReviewPage reviewedWork={reviewedWork} />
