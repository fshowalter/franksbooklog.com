---
import { getCollection } from "astro:content";

import HeroLayout from "~/components/layout/HeroLayout.astro";
import { getReviewsProps } from "~/features/reviews/getReviewsProps";
import { Reviews } from "~/features/reviews/Reviews";

const [worksEntries, reviewsEntries, authorsEntries, readingsEntries] =
  await Promise.all([
    getCollection("works"),
    getCollection("reviews"),
    getCollection("authors"),
    getCollection("readings"),
  ]);
const works = worksEntries.map((e) => e.data);
const reviews = reviewsEntries.map((e) => e.data);
const authors = authorsEntries.map((e) => e.data);
const readings = readingsEntries.map((e) => e.data);
const reviewsProps = await getReviewsProps(works, reviews, authors, readings);

const title = "Reviews";
const deck = `"You were always the best of them, Lloyd."`;
const metaDescription =
  "All my book and story reviews. Filter by title, kind, review date, work date, or grade. Sort by best or worst, oldest or newest, author, or title.";
---

<HeroLayout
  baseLayoutProps={{
    canonical: true,
    meta: {
      description: metaDescription,
    },
    openGraph: {
      description: deck,
      type: "website",
    },
    title,
  }}
  heroProps={{
    backdropSlug: "reviews",
    deck,
    title,
  }}
>
  <Reviews client:load {...reviewsProps} />
</HeroLayout>
