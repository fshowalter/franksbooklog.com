---
import { getEntry } from "astro:content";

import Article from "~/components/article/Article.astro";
import HeroLayout from "~/components/layout/HeroLayout.astro";

const slug = "how-i-grade";
const page = await getEntry("pages", slug);

if (!page) {
  throw new Error(`page with id "${slug}" not found in collection "pages"`);
}

const deck = `"I want you to hit me as hard as you can."`;
---

<HeroLayout
  baseLayoutProps={{
    canonical: true,
    meta: {
      description: page.data.description,
    },
    openGraph: {
      description: deck,
      type: "article",
    },
    title: page.data.title,
  }}
  data-pagefind-body
  heroProps={{
    backdropSlug: slug,
    centerText: true,
    deck,
    size: "large",
    title: page.data.title,
  }}
>
  <Article content={page.data.intermediateHtml} />
</HeroLayout>
