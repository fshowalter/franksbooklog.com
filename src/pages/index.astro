---
import { getCollection } from "astro:content";

import HeroLayout from "~/components/layout/HeroLayout.astro";
import { getHomeProps } from "~/features/home/getHomeProps";
import { Home } from "~/features/home/Home";

const [worksEntries, reviewsEntries, authorsEntries, readingsEntries] =
  await Promise.all([
    getCollection("works"),
    getCollection("reviews"),
    getCollection("authors"),
    getCollection("readings"),
  ]);
const works = worksEntries.map((e) => e.data);
const reviews = reviewsEntries.map((e) => e.data);
const authors = authorsEntries.map((e) => e.data);
const readings = readingsEntries.map((e) => e.data);
const homeProps = await getHomeProps(works, reviews, authors, readings);

const deck = "Literature is a relative term.";
const metaDescription =
  "Quality reviews of current, cult, classic, and forgotten books, short stories, and non-fiction. Literature is a relative term.";
---

<HeroLayout
  baseLayoutProps={{
    canonical: true,
    meta: {
      description: metaDescription,
    },
    openGraph: { description: deck, type: "website" },
    title: "Frank's Book Log",
  }}
  heroProps={{
    backdropSlug: "home",
    deck,
    title: "Frank's Book Log",
  }}
  hideLogo={true}
>
  <Home {...homeProps} />
</HeroLayout>
