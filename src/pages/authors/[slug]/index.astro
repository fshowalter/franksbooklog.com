---
import { getCollection } from "astro:content";

import type { Author } from "~/api/authors";

import { allAuthors } from "~/api/authors";
import HeroLayout from "~/components/layout/HeroLayout.astro";
import { AuthorTitles } from "~/features/author-titles/AuthorTitles";
import { getAuthorTitlesProps } from "~/features/author-titles/getAuthorTitlesProps";

type Props = Author;

export async function getStaticPaths() {
  const authorEntries = await getCollection("authors");
  const authors = authorEntries.map((e) => e.data);

  return allAuthors(authors).map((author) => {
    return {
      params: {
        slug: author.slug,
      },
      props: author,
    };
  });
}

const { name, slug } = Astro.props;

const authorTitlesProps = await getAuthorTitlesProps(slug);

const reviewedWorkCount = authorTitlesProps.values.length;

let worksLabel = "works";

if (reviewedWorkCount === 1) {
  worksLabel = "work";
}

const deck = `Author of ${reviewedWorkCount} reviewed ${worksLabel}.`;
const metaDescription = `Reviews of books and stories written by ${name}. Sort reviews by best or worst, newest or oldest. Filter by year, kind, or title.`;
---

<HeroLayout
  baseLayoutProps={{
    canonical: true,
    meta: {
      description: metaDescription,
    },
    openGraph: {
      description: deck,
      type: "website",
    },
    title: `${name} book & story reviews`,
  }}
  heroProps={{
    avatarSlug: slug,
    backdropSlug: "author",
    breadcrumb: {
      href: "/authors/",
      text: "Authors",
    },
    centerText: true,
    deck,
    title: name,
  }}
>
  <AuthorTitles client:load {...authorTitlesProps} />
</HeroLayout>
