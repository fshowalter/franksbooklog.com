---
import type { CollectionEntry } from "astro:content";

import { getCollection } from "astro:content";

import AuthorTitlesPage from "~/features/author-titles/AuthorTitlesPage.astro";

type Props = {
  reviewedAuthor: CollectionEntry<"reviewedAuthors">["data"];
};

export async function getStaticPaths() {
  const reviewedAuthors = await getCollection("reviewedAuthors");

  return reviewedAuthors.map(({ data: reviewedAuthor }) => {
    return {
      params: {
        slug: reviewedAuthor.slug,
      },
      props: { reviewedAuthor },
    };
  });
}

const { reviewedAuthor } = Astro.props;
---

<AuthorTitlesPage reviewedAuthor={reviewedAuthor} />
