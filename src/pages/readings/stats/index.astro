---
import { getCollection } from "astro:content";

import { allStatYears } from "~/api/stats";
import HeroLayout from "~/components/layout/HeroLayout.astro";
import { AlltimeStats } from "~/features/stats/AlltimeStats";
import { getAlltimeStatsProps } from "~/features/stats/getStatsProps";

const alltimeEntries = await getCollection("alltimeStats");
const data = alltimeEntries[0].data;
const yearStatsEntries = await getCollection("yearStats");
const yearStats = yearStatsEntries.map((e) => e.data);

const alltimeStatsProps = await getAlltimeStatsProps(data, yearStats);
const distinctStatYears = allStatYears(yearStats);

const title = "All-Time Stats";
const deck = `${(distinctStatYears.length - 1).toString()} Years in Review`;
const metaDescription =
  "My all-time reading stats. Includes my most-read authors, as well as grade, kind, release year, and edition distributions.";
---

<HeroLayout
  baseLayoutProps={{
    canonical: true,
    meta: {
      description: metaDescription,
    },
    openGraph: {
      description: deck,
      type: "website",
    },
    title,
  }}
  heroProps={{
    backdropSlug: "stats",
    breadcrumb: {
      href: "/readings/",
      text: "Reading Log",
    },
    centerText: true,
    deck,
    title: "All-Time Stats",
  }}
>
  <AlltimeStats {...alltimeStatsProps} />
</HeroLayout>
