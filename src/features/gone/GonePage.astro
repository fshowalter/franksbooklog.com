---
import HeroLayout from "~/components/astro/layout/HeroLayout.astro";

const deck = '"This is not an exit."';
const title = "410 Gone";
---

<HeroLayout
  baseLayoutProps={{
    canonical: false,
    meta: {
      description: deck,
    },
    openGraph: false,
    title,
  }}
  heroProps={{
    backdropSlug: "gone",
    centerText: true,
    deck,
    size: "large",
    title,
  }}
/>
