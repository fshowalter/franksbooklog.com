---
import type { CollectionEntry } from "astro:content";

import { getEntry } from "astro:content";

import ListItemAuthors from "~/components/list-item-authors/ListItemAuthors.astro";
import ListItemDetails from "~/components/list-item-details/ListItemDetails.astro";
import ListItemGrade from "~/components/list-item-grade/ListItemGrade.astro";
import ListItemKindAndYear from "~/components/list-item-kind-and-year/ListItemKindAndYear.astro";
import ListItemTitle from "~/components/list-item-title/ListItemTitle.astro";
import SubHeading from "~/components/sub-heading/SubHeading.astro";

type Props = {
  includedWorks: CollectionEntry<"reviewedWorks">[];
};
const { includedWorks } = Astro.props;
---

{
  includedWorks.length > 0 && (
    <div class="w-full max-w-popout">
      <SubHeading class="text-center shadow-bottom" level="h2">
        Included Works
      </SubHeading>
      <div
        class={`
          w-full max-w-popout bg-subtle px-container py-8
          tablet:pt-12
        `}
      >
        <ul>
          {includedWorks.map(async ({ data: reviewedWork }) => {
            const { data: includedWorkReview } = await getEntry(
              reviewedWork.review,
            );

            return (
              <li
                class={`
                  relative mb-1 transform-gpu bg-default px-container py-4
                  transition-transform
                  last-of-type:mb-0
                  has-[a:hover]:z-10 has-[a:hover]:scale-105
                  has-[a:hover]:shadow-all has-[a:hover]:drop-shadow-2xl
                  tablet:gap-x-6 tablet:px-4
                  desktop:px-6
                `}
              >
                <ListItemDetails>
                  <ListItemTitle
                    slug={includedWorkReview.slug}
                    title={reviewedWork.title}
                  />
                  <ListItemAuthors values={reviewedWork.authors} />
                  <ListItemKindAndYear
                    kind={reviewedWork.kind}
                    year={reviewedWork.workYear}
                  />
                  {includedWorkReview.grade && (
                    <ListItemGrade grade={includedWorkReview.grade} />
                  )}
                </ListItemDetails>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  )
}
