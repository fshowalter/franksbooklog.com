---
import { getFixedCoverImageProps } from "~/assets/covers";

type Props = {
  coverSlug: string;
};

/**
 * Configuration for cover images in the review page.
 * Defines the width for the main review cover image.
 */
const CoverImageConfig = {
  /** Cover image width in pixels */
  width: 248,
};

const { coverSlug } = Astro.props;

const coverImageProps = await getFixedCoverImageProps(
  coverSlug,
  CoverImageConfig,
);
---

<div
  class={`
    @container relative my-12 flex w-full max-w-popout flex-col items-center
  `}
  data-pagefind-meta={`image:${coverImageProps.src}`}
>
  <div
    class={`
      absolute top-[2.5%] left-[2.5%] size-[95%] overflow-hidden bg-default
      bg-cover bg-center clip-path-cover
      after:absolute after:size-full after:backdrop-blur-sm
      after:clip-path-cover
      tablet:-left-[2.5%] tablet:w-[105%]
    `}
    style={{
      "background-color": "var(--background-color-default)",
      "background-image": `linear-gradient(90deg, rgba(var(--bg-default-rgb),1) 0%, rgba(var(--bg-default-rgb),var(--bg-default-alpha)) 30%, rgba(var(--bg-default-rgb),0) 50%, rgba(var(--bg-default-rgb),var(--bg-default-alpha)) 70%, rgba(var(--bg-default-rgb),1) 100%), url(${coverImageProps.src})`,
    }}
  >
  </div>
  <div
    class={`
      relative -top-[2.5%]
      after:absolute after:top-0 after:left-0 after:z-20 after:block
      after:size-full after:rounded-[2.5px] after:bg-[url(/assets/spot.png)]
      after:bg-size-[100%_100%] after:mix-blend-soft-light
    `}
  >
    <div
      class={`
        relative z-10
        before:absolute before:top-0 before:left-0 before:z-10 before:block
        before:size-full before:rounded-[2.5px]
        before:bg-[url(/assets/spine-light.png)] before:bg-size-[100%_100%]
        after:absolute after:top-0 after:left-0 after:z-10 after:block
        after:size-full after:rounded-[2.5px]
        after:bg-[url(/assets/spine-dark.png)] after:bg-size-[100%_100%]
        after:mix-blend-multiply
      `}
    >
      <img
        alt=""
        class={`
          rounded-[2.5px] bg-default shadow-sm
          @min-[160px]:shadow-lg
        `}
        decoding={"auto"}
        loading={"eager"}
        {...coverImageProps}
      />
    </div>
  </div>
</div>
