---
import type { CollectionEntry } from "astro:content";

import { getEntry } from "astro:content";

import { ListItemAuthors } from "~/components/list-item-authors/ListItemAuthors";
import { ListItemDetails } from "~/components/list-item-details/ListItemDetails";
import { ListItemGrade } from "~/components/list-item-grade/ListItemGrade";
import { ListItemKindAndYear } from "~/components/list-item-kind-and-year/ListItemKindAndYear";
import { ListItemTitle } from "~/components/list-item-title/ListItemTitle";
import SubHeading from "~/components/sub-heading/SubHeading.astro";

type Props = {
  includedTitles: CollectionEntry<"reviewedTitles">[];
};
const { includedTitles } = Astro.props;
---

{
  includedTitles.length > 0 && (
    <div class="w-full max-w-popout">
      <SubHeading class="text-center shadow-bottom" level="h2">
        Included Works
      </SubHeading>
      <div
        class={`
          w-full max-w-popout bg-subtle px-container py-8
          tablet:pt-12
        `}
      >
        <ul>
          {includedTitles.map(async ({ data: reviewedTitle }) => {
            const { data: includedTitleReview } = await getEntry(
              reviewedTitle.review,
            );

            return (
              <li
                class={`
                  relative mb-1 transform-gpu bg-default px-container py-4
                  transition-transform
                  last-of-type:mb-0
                  has-[a:hover]:z-10 has-[a:hover]:scale-105
                  has-[a:hover]:shadow-all has-[a:hover]:drop-shadow-2xl
                  tablet:gap-x-6 tablet:px-4
                  desktop:px-6
                `}
              >
                <ListItemDetails>
                  <ListItemTitle
                    slug={includedTitleReview.slug}
                    title={reviewedTitle.title}
                  />
                  <ListItemAuthors values={reviewedTitle.authors} />
                  <ListItemKindAndYear
                    kind={reviewedTitle.kind}
                    year={reviewedTitle.titleYear}
                  />
                  {includedTitleReview.grade && (
                    <ListItemGrade grade={includedTitleReview.grade} />
                  )}
                </ListItemDetails>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  )
}
