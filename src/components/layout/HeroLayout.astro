---
import type { ComponentProps } from "astro/types";

import BaseLayout from "./BaseLayout.astro";
import Hero from "./Hero.astro";
import { Mast } from "./Mast";

export type Props = {
  baseLayoutProps: Omit<ComponentProps<typeof BaseLayout>, "children">;
  children: any;
  heroProps: ComponentProps<typeof Hero>;
  hideLogo?: boolean;
};

const { baseLayoutProps, heroProps, hideLogo = false, ...rest } = Astro.props;
---

<BaseLayout {...baseLayoutProps} {...rest}>
  <Mast addGradient={true} hasBackdrop={true} hideLogo={hideLogo} slot="mast" />
  <Hero {...heroProps} />
  <slot />
</BaseLayout>
