---
type Props = {
  children: any;
  classNames?: string;
  element: "h2" | "h3" | "h4" | "h5";
};

const { classNames, element } = Astro.props;

const Element = element;
---

<Element
  class:list={[
    `py-10 font-sans text-xs font-bold tracking-wide text-subtle uppercase`,
    classNames,
  ]}
>
  <slot />
</Element>
